# ─── Synaptiq Environment Variables ───────────────────────────────────────────
# Copy this file to .env.local for local development.
# In production, set these in the Vercel dashboard under
# Project → Settings → Environment Variables.
# NEVER commit a .env file with real values to version control.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project → Settings → API

# Your project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Service role key — has full DB access, NEVER expose client-side
SUPABASE_SERVICE_KEY=

# Anon/public key — used for client-auth flows (verify_login, forgot_password)
SUPABASE_ANON_KEY=

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Found in: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Deepgram (speech-to-text) ─────────────────────────────────────────────────
# Used by /api/transcribe to convert user voice recordings to text (nova-2 model).
# Without this key the /api/transcribe endpoint returns 503.
# Found in: https://console.deepgram.com → API Keys
# Free tier: 200 hours/year
DEEPGRAM_API_KEY=

# ── ElevenLabs (TTS voice) ────────────────────────────────────────────────────
# Used by /api/tts to power natural-sounding British voice in the AI Tutor and
# Talk to Teacher features (Alice voice via eleven_turbo_v2_5 model).
# Without this key the app falls back to the browser's built-in speech engine.
# Found in: https://elevenlabs.io → Profile → API Key
# Free tier: 10,000 characters/month
ELEVENLABS_API_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Found in: Stripe dashboard → Developers → API Keys
# Use sk_test_... for development, sk_live_... for production
STRIPE_SECRET_KEY=

# Price IDs — create in Stripe dashboard → Products
# Student plan: £20/month
STRIPE_PRICE_STUDENT=price_

# Student plan: £199/year
STRIPE_PRICE_STUDENT_ANNUAL=price_

# School/institution plan: £200/month
STRIPE_PRICE_HOMESCHOOL=price_

# ── Resend (email) ────────────────────────────────────────────────────────────
# Found in: https://resend.com → API Keys
# Also verify the domain hello@synaptiq.co.uk in Resend → Domains
RESEND_API_KEY=re_

# ── App ───────────────────────────────────────────────────────────────────────
# Your production URL — used in email links and Stripe redirect URLs
APP_URL=https://synaptiq.co.uk

# ── Google Analytics 4 Measurement ID (optional — leave blank to disable) ─────
# Found in: GA4 → Admin → Data Streams → your stream → Measurement ID
GA4_MEASUREMENT_ID=G-

# ── J.A.R.V.I.S. — Conversational AI ─────────────────────────────────────────
# ElevenLabs Conversational AI agent ID — the voice/brain of JARVIS.
# Found in: https://elevenlabs.io → Conversational AI → your agent → Agent ID
ELEVEN_AGENT_ID=agent_4101kn5cm6t2efwsasfhx8cgh1r3

# For Next.js client-side (browser) usage — safe to expose
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
